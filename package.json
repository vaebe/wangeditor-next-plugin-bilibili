{
  "name": "@vaebe/wangeditor-next-plugin-bilibili",
  "version": "0.1.1",
  "description": "Bilibili video plugin for wangEditor-next: insert, paste-parse, render and serialize Bilibili videos.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "wangeditor",
    "wangeditor-next",
    "bilibili",
    "video",
    "plugin",
    "rich-text-editor"
  ],
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.32.1",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "release": "pnpm build && changeset publish"
  },
  "peerDependencies": {
    "@wangeditor-next/editor": ">=5.0.0"
  },
  "dependencies": {
    "snabbdom": "^3.6.2"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "@wangeditor-next/editor": "^5.7.8",
    "eslint": "^10.4.1",
    "jsdom": "^29.1.1",
    "tsup": "^8.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.11.0",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}